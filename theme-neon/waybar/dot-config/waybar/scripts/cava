#!/usr/bin/env bash

bar="‚ĖĀ‚Ėā‚ĖÉ‚ĖĄ‚ĖÖ‚ĖÜ‚Ėá‚Ėą"
dict="s/;//g;"

i=0
while [ $i -lt ${#bar} ]; do
    dict="${dict}s/$i/${bar:$i:1}/g;"
    i=$((i + 1))
done

config_file=$(mktemp)
trap 'rm -f "$config_file"' EXIT

cat > "$config_file" << 'EOF'
[general]
bars = 8

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
EOF

cava -p "$config_file" | while read -r line; do
    echo "$line" | sed "$dict"
done
